<mujoco model="go1_juggle">
    <!-- Go1 quadruped + juggling ball.
         Meshes from walk-these-ways; ball radius 0.020m matching Isaac Lab.
         Ball restitution ~0.85 via tight solref + high solimp.
    -->
    <compiler angle="radian"
              meshdir="/home/frank/berkeley_mde/walk-these-ways/resources/robots/go1/meshes/" />
    <size njmax="500" nconmax="200" />
    <option gravity="0 0 -9.806" iterations="50" solver="Newton" timestep="0.005"/>

    <default>
        <geom contype="1" conaffinity="1" friction="0.6 0.3 0.3"
              rgba="0.5 0.6 0.7 1" margin="0.001" group="0"/>
        <light castshadow="false" diffuse="1 1 1"/>
        <motor ctrlrange="-33.5 33.5" ctrllimited="true"/>
        <camera fovy="60"/>
        <joint damping="0.5" armature="0.01" frictionloss="0.0"/>
    </default>

    <asset>
        <mesh name="trunk"        file="trunk.stl" />
        <mesh name="hip"          file="hip.stl" />
        <mesh name="thigh_mirror" file="thigh_mirror.stl" />
        <mesh name="calf"         file="calf.stl" />
        <mesh name="thigh"        file="thigh.stl" />
        <texture type="skybox" builtin="gradient"
                 rgb1="0.8 0.9 1.0" rgb2="1.0 1.0 1.0" width="512" height="512"/>
        <texture name="plane" type="2d" builtin="flat"
                 rgb1="0.85 0.85 0.85" rgb2="0.85 0.85 0.85"
                 width="512" height="512" mark="cross" markrgb="0.5 0.5 0.5"/>
        <material name="plane" reflectance="0.0" texture="plane"
                  texrepeat="5 5" texuniform="true"/>
    </asset>

    <visual>
        <rgba com="0.502 1.0 0 0.5" contactforce="0.98 0.4 0.4 0.7"
              contactpoint="1.0 1.0 0.6 0.4"/>
        <scale com="0.2" forcewidth="0.035" contactwidth="0.10" contactheight="0.04"/>
    </visual>

    <worldbody>
        <light directional="true" diffuse=".8 .8 .8" pos="0 0 10" dir="0 0 -10"/>
        <!-- Camera that tracks the robot trunk -->
        <camera name="track" mode="trackcom" pos="0 -1.8 1.4" xyaxes="1 0 0 0 0.707 0.707"/>
        <geom name="floor" type="plane" conaffinity="1" condim="3" contype="1"
              rgba="0.7 0.8 0.7 1" material="plane" pos="0 0 0" size="0 0 1"/>

        <!-- ── Go1 robot trunk ─────────────────────────────────── -->
        <!-- trunk_z=0.35 near the WTW natural standing height -->
        <body name="trunk" pos="0 0 0.35">
            <inertial pos="0.0116053 0.00442221 0.000106692"
                      quat="0.0111438 0.707126 -0.00935374 0.706938"
                      mass="4.801" diaginertia="0.0447997 0.0366257 0.0162187"/>
            <joint type="free"/>
            <geom type="mesh" contype="0" conaffinity="0" group="1"
                  rgba="0.913725 0.913725 0.847059 1" mesh="trunk"/>
            <geom name="trunk_box" size="0.13 0.04675 0.057" type="box"
                  rgba="0.913725 0.913725 0.847059 1"/>
            <site name="imu"    pos="0 0 0"/>
            <!-- Paddle: radius=0.153m, half-height=0.0035m (thin disc, tunneling prevented by margin in contact pair) -->
            <geom name="paddle" type="cylinder" size="0.153 0.0035" pos="0 0 0.07"
                  rgba="0.2 0.6 1.0 0.7" contype="1" conaffinity="1"
                  mass="0.15"/>
            <site name="paddle_site" pos="0 0 0.07"/>

            <!-- Front-Right leg -->
            <body name="FR_hip" pos="0.1881 -0.04675 0">
                <inertial pos="-0.00406411 -0.0193463 4.50733e-06"
                          quat="0.467526 0.531662 -0.466259 0.530431"
                          mass="0.679292" diaginertia="0.00131334 0.00122648 0.000728484"/>
                <joint name="FR_hip_joint" pos="0 0 0" axis="1 0 0"
                       limited="true" range="-0.802851 0.802851"/>
                <geom quat="0 1 0 0" type="mesh" contype="0" conaffinity="0"
                      group="1" rgba="0.913725 0.913725 0.847059 1" mesh="hip"/>
                <geom name="FR_hip_geom" size="0.046 0.02" pos="0 -0.045 0" quat="0.707107 0.707107 0 0"
                      type="cylinder" rgba="0.913725 0.913725 0.847059 0"/>
                <body name="FR_thigh" pos="0 -0.08 0">
                    <inertial pos="-0.003468 0.018947 -0.032736"
                              quat="0.999266 0.00067676 -0.0382978 0.000639813"
                              mass="0.898919" diaginertia="0.00542178 0.00514246 0.000998869"/>
                    <joint name="FR_thigh_joint" pos="0 0 0" axis="0 1 0"
                           limited="true" range="-1.0472 4.18879"/>
                    <geom type="mesh" contype="0" conaffinity="0" group="1"
                          rgba="0.913725 0.913725 0.847059 1" mesh="thigh_mirror"/>
                    <geom size="0.1065 0.01225 0.017" pos="0 0 -0.1065"
                          quat="0.707107 0 0.707107 0" type="box"
                          rgba="0.913725 0.913725 0.847059 0"/>
                    <body name="FR_calf" pos="0 0 -0.213">
                        <inertial pos="0.00455603 0.0009473 -0.147239"
                                  quat="0.762045 0.00970173 0.0180098 0.647201"
                                  mass="0.218015" diaginertia="0.00399678 0.00398122 3.99428e-05"/>
                        <joint name="FR_calf_joint" pos="0 0 0" axis="0 1 0"
                               limited="true" range="-2.69653 -0.916298"/>
                        <geom type="mesh" contype="0" conaffinity="0" group="1"
                              rgba="0 0 0 1" mesh="calf"/>
                        <geom size="0.02" pos="0 0 -0.213" rgba="0 0 0 1"/>
                    </body>
                </body>
            </body>

            <!-- Front-Left leg -->
            <body name="FL_hip" pos="0.1881 0.04675 0">
                <inertial pos="-0.00406411 0.0193463 4.50733e-06"
                          quat="0.531662 0.467526 -0.530431 0.466259"
                          mass="0.679292" diaginertia="0.00131334 0.00122648 0.000728484"/>
                <joint name="FL_hip_joint" pos="0 0 0" axis="1 0 0"
                       limited="true" range="-0.802851 0.802851"/>
                <geom type="mesh" contype="0" conaffinity="0" group="1"
                      rgba="0.913725 0.913725 0.847059 1" mesh="hip"/>
                <geom name="FL_hip_geom" size="0.046 0.02" pos="0 0.045 0" quat="0.707107 0.707107 0 0"
                      type="cylinder" rgba="0.913725 0.913725 0.847059 0"/>
                <body name="FL_thigh" pos="0 0.08 0">
                    <inertial pos="-0.003468 -0.018947 -0.032736"
                              quat="0.999266 -0.00067676 -0.0382978 -0.000639813"
                              mass="0.898919" diaginertia="0.00542178 0.00514246 0.000998869"/>
                    <joint name="FL_thigh_joint" pos="0 0 0" axis="0 1 0"
                           limited="true" range="-1.0472 4.18879"/>
                    <geom type="mesh" contype="0" conaffinity="0" group="1"
                          rgba="0.913725 0.913725 0.847059 1" mesh="thigh"/>
                    <geom size="0.1065 0.01225 0.017" pos="0 0 -0.1065"
                          quat="0.707107 0 0.707107 0" type="box"
                          rgba="0.913725 0.913725 0.847059 0"/>
                    <body name="FL_calf" pos="0 0 -0.213">
                        <inertial pos="0.00455603 0.0009473 -0.147239"
                                  quat="0.762045 0.00970173 0.0180098 0.647201"
                                  mass="0.218015" diaginertia="0.00399678 0.00398122 3.99428e-05"/>
                        <joint name="FL_calf_joint" pos="0 0 0" axis="0 1 0"
                               limited="true" range="-2.69653 -0.916298"/>
                        <geom type="mesh" contype="0" conaffinity="0" group="1"
                              rgba="0 0 0 1" mesh="calf"/>
                        <geom size="0.02" pos="0 0 -0.213" rgba="0 0 0 1"/>
                    </body>
                </body>
            </body>

            <!-- Rear-Right leg -->
            <body name="RR_hip" pos="-0.1881 -0.04675 0">
                <inertial pos="0.00406411 -0.0193463 4.50733e-06"
                          quat="0.530431 0.466259 -0.531662 0.467526"
                          mass="0.679292" diaginertia="0.00131334 0.00122648 0.000728484"/>
                <joint name="RR_hip_joint" pos="0 0 0" axis="1 0 0"
                       limited="true" range="-0.802851 0.802851"/>
                <geom quat="0 0 0 -1" type="mesh" contype="0" conaffinity="0"
                      group="1" rgba="0.913725 0.913725 0.847059 1" mesh="hip"/>
                <geom name="RR_hip_geom" size="0.046 0.02" pos="0 -0.045 0" quat="0.707107 0.707107 0 0"
                      type="cylinder" rgba="0.913725 0.913725 0.847059 0"/>
                <body name="RR_thigh" pos="0 -0.08 0">
                    <inertial pos="-0.003468 0.018947 -0.032736"
                              quat="0.999266 0.00067676 -0.0382978 0.000639813"
                              mass="0.898919" diaginertia="0.00542178 0.00514246 0.000998869"/>
                    <joint name="RR_thigh_joint" pos="0 0 0" axis="0 1 0"
                           limited="true" range="-1.0472 4.18879"/>
                    <geom type="mesh" contype="0" conaffinity="0" group="1"
                          rgba="0.913725 0.913725 0.847059 1" mesh="thigh_mirror"/>
                    <geom size="0.1065 0.01225 0.017" pos="0 0 -0.1065"
                          quat="0.707107 0 0.707107 0" type="box"
                          rgba="0.913725 0.913725 0.847059 0"/>
                    <body name="RR_calf" pos="0 0 -0.213">
                        <inertial pos="0.00455603 0.0009473 -0.147239"
                                  quat="0.762045 0.00970173 0.0180098 0.647201"
                                  mass="0.218015" diaginertia="0.00399678 0.00398122 3.99428e-05"/>
                        <joint name="RR_calf_joint" pos="0 0 0" axis="0 1 0"
                               limited="true" range="-2.69653 -0.916298"/>
                        <geom type="mesh" contype="0" conaffinity="0" group="1"
                              rgba="0 0 0 1" mesh="calf"/>
                        <geom size="0.02" pos="0 0 -0.213" rgba="0 0 0 1"/>
                    </body>
                </body>
            </body>

            <!-- Rear-Left leg -->
            <body name="RL_hip" pos="-0.1881 0.04675 0">
                <inertial pos="0.00406411 0.0193463 4.50733e-06"
                          quat="0.466259 0.530431 -0.467526 0.531662"
                          mass="0.679292" diaginertia="0.00131334 0.00122648 0.000728484"/>
                <joint name="RL_hip_joint" pos="0 0 0" axis="1 0 0"
                       limited="true" range="-0.802851 0.802851"/>
                <geom quat="0 0 1 0" type="mesh" contype="0" conaffinity="0"
                      group="1" rgba="0.913725 0.913725 0.847059 1" mesh="hip"/>
                <geom name="RL_hip_geom" size="0.046 0.02" pos="0 0.07 0" quat="0.707107 0.707107 0 0"
                      type="cylinder" rgba="0.913725 0.913725 0.847059 0"/>
                <body name="RL_thigh" pos="0 0.08 0">
                    <inertial pos="-0.003468 -0.018947 -0.032736"
                              quat="0.999266 -0.00067676 -0.0382978 -0.000639813"
                              mass="0.898919" diaginertia="0.00542178 0.00514246 0.000998869"/>
                    <joint name="RL_thigh_joint" pos="0 0 0" axis="0 1 0"
                           limited="true" range="-1.0472 4.18879"/>
                    <geom type="mesh" contype="0" conaffinity="0" group="1"
                          rgba="0.913725 0.913725 0.847059 1" mesh="thigh"/>
                    <geom size="0.1065 0.01225 0.017" pos="0 0 -0.1065"
                          quat="0.707107 0 0.707107 0" type="box"
                          rgba="0.913725 0.913725 0.847059 0"/>
                    <body name="RL_calf" pos="0 0 -0.213">
                        <inertial pos="0.00455603 0.0009473 -0.147239"
                                  quat="0.762045 0.00970173 0.0180098 0.647201"
                                  mass="0.218015" diaginertia="0.00399678 0.00398122 3.99428e-05"/>
                        <joint name="RL_calf_joint" pos="0 0 0" axis="0 1 0"
                               limited="true" range="-2.69653 -0.916298"/>
                        <geom type="mesh" contype="0" conaffinity="0" group="1"
                              rgba="0 0 0 1" mesh="calf"/>
                        <geom size="0.02" pos="0 0 -0.213" rgba="0 0 0 1"/>
                    </body>
                </body>
            </body>
        </body>

        <!-- ── Juggling ball ──────────────────────────────────────── -->
        <!-- Starts ~0.12 m above paddle (paddle at ~0.38 m, ball at 0.50 m) -->
        <body name="ball" pos="0 0 1.00">
            <joint name="ball_free" type="free"
                   damping="0" armature="0" frictionloss="0"/>
            <geom name="ball_geom" type="sphere" size="0.020" mass="0.0027"
                  rgba="1.0 0.4 0.0 1"
                  contype="1" conaffinity="1"
                  friction="0.3 0.3 0.3"/>
        </body>
    </worldbody>

    <!-- ── Contact pairs: elastic ball-paddle bounce ──────────── -->
    <!-- Matches Isaac Lab restitution=0.99, restitution_combine_mode=max.
         solref=[-k, -b]: k=2e5 N/m (stiff), b=0.1 N·s/m (near-zero damping)
         → damping ratio ζ ≈ 0.1/(2√(2e5·0.0027)) ≈ 0.00068  → e ≈ 0.99 -->
    <contact>
        <!-- Ball-paddle: high restitution (~0.99), stiff spring, margin prevents tunneling -->
        <pair geom1="ball_geom" geom2="paddle"
            solref="-20000 -0.1"
            solimp="0.8 0.95 0.001 0.5 2"
            margin="0.025"/>
        <!-- Ball-body (trunk + hip motors): tunable elasticity, margin prevents tunneling -->
        <pair geom1="ball_geom" geom2="trunk_box"   solref="-20000 -5.0" solimp="0.8 0.95 0.001 0.5 2" margin="0.025"/>
        <pair geom1="ball_geom" geom2="FR_hip_geom" solref="-20000 -5.0" solimp="0.8 0.95 0.001 0.5 2" margin="0.025"/>
        <pair geom1="ball_geom" geom2="FL_hip_geom" solref="-20000 -5.0" solimp="0.8 0.95 0.001 0.5 2" margin="0.025"/>
        <pair geom1="ball_geom" geom2="RR_hip_geom" solref="-20000 -5.0" solimp="0.8 0.95 0.001 0.5 2" margin="0.025"/>
        <pair geom1="ball_geom" geom2="RL_hip_geom" solref="-20000 -5.0" solimp="0.8 0.95 0.001 0.5 2" margin="0.025"/>
        <!-- Ball-floor: e≈0.87 (b=2.0, ζ=b/(2√km)=0.043) — ball bounces visibly off ground -->
        <pair geom1="ball_geom" geom2="floor"
              solref="-5000 -1"
              solimp="0.8 0.95 0.001 0.5 2"/>
    </contact>

    <!-- <contact>
    <pair geom1="ball_geom" geom2="paddle"
          solref="-100 -0.1" 
          solimp="0.8 0.95 0.001 0.5 2"/>
    <pair geom1="ball_geom" geom2="floor"
          solref="-100 -5.0"
          solimp="0.8 0.95 0.001 0.5 2"/>
     </contact> -->

    <!-- ── Actuators (torque control, PD applied in script) ─── -->
    <!-- Order: FR, FL, RR, RL  (matches go1.xml actuator order) -->
    <actuator>
        <motor name="FR_hip"   gear="1" joint="FR_hip_joint"/>
        <motor name="FR_thigh" gear="1" joint="FR_thigh_joint"/>
        <motor name="FR_calf"  gear="1" joint="FR_calf_joint"/>
        <motor name="FL_hip"   gear="1" joint="FL_hip_joint"/>
        <motor name="FL_thigh" gear="1" joint="FL_thigh_joint"/>
        <motor name="FL_calf"  gear="1" joint="FL_calf_joint"/>
        <motor name="RR_hip"   gear="1" joint="RR_hip_joint"/>
        <motor name="RR_thigh" gear="1" joint="RR_thigh_joint"/>
        <motor name="RR_calf"  gear="1" joint="RR_calf_joint"/>
        <motor name="RL_hip"   gear="1" joint="RL_hip_joint"/>
        <motor name="RL_thigh" gear="1" joint="RL_thigh_joint"/>
        <motor name="RL_calf"  gear="1" joint="RL_calf_joint"/>
    </actuator>
</mujoco>
