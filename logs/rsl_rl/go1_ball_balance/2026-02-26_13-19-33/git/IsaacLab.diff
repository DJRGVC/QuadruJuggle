-[settings.physics]
-autoPopupSimulationOutputWindow = false
-updateToUsd = false
-updateVelocitiesToUsd = false
-updateParticlesToUsd = false
-updateVelocitiesToUsd = false
-updateForceSensorsToUsd = false
